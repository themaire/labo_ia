# Exemple de configuration pour l'application Flask Ticket Carburant
# Renommez ce fichier en ".env" et adaptez les valeurs selon votre environnement

# Variables de connexion à la base PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=motdepasse
POSTGRES_DB=ia_workflows
POSTGRES_SCHEMA=pictures

# Authentification JWT
JWT_SECRET_KEY=remplacez-par-une-cle-aleatoire-longue-et-secrete
JWT_EXPIRY_DAYS=30

# Clé secrète Flask (sessions web)
FLASK_SECRET_KEY=remplacez-par-une-autre-cle-aleatoire-differente

# Activation du mode debug
DEBUG_AUTH=False